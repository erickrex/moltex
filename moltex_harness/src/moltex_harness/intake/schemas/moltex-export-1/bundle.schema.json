{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moltex.dev/schemas/moltex-export-1/bundle.schema.json",
  "title": "Moltex export bundle manifest",
  "type": "object",
  "required": ["schema", "manifest_version", "bundle_id", "created_at", "exporter_version", "mode", "site_origin", "complete", "privacy", "counts", "artifacts", "artifact_registry"],
  "properties": {
    "schema": {"type": "string", "const": "moltex-export/1"},
    "manifest_version": {"type": "integer", "const": 1},
    "bundle_id": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "created_at": {"type": "string", "minLength": 1},
    "exporter_version": {"type": "string", "minLength": 1},
    "mode": {"type": "string", "enum": ["complete", "discovery"]},
    "site_origin": {"type": "string", "minLength": 1},
    "complete": {"type": "boolean"},
    "privacy": {"type": "object"},
    "counts": {"type": "object"},
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "kind", "producer", "required", "schema", "bytes", "sha256"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "kind": {"type": "string", "minLength": 1},
          "producer": {"type": "string", "minLength": 1},
          "required": {"type": "boolean"},
          "schema": {"type": ["string", "null"]},
          "bytes": {"type": "integer", "minimum": 0},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    },
    "artifact_registry": {"type": "array", "minItems": 1, "items": {"type": "object"}}
  }
}

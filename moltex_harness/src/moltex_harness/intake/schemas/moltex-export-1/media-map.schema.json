{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moltex.dev/schemas/moltex-export-1/media-map.schema.json",
  "title": "Moltex media map",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["wp_src", "artifact"],
    "properties": {
      "wp_src": {"type": "string", "minLength": 1},
      "artifact": {"type": ["string", "null"]},
      "type": {"type": "string"},
      "note": {"type": "string"},
      "metadata": {"type": "object"},
      "acquisition": {
        "type": "object",
        "required": ["status", "method", "runtime_policy"],
        "properties": {
          "status": {"enum": ["bundled", "deferred", "unavailable"]},
          "method": {"enum": ["bundle", "source-fetch", "operator-decision"]},
          "runtime_policy": {"const": "local-only"}
        },
        "additionalProperties": false
      }
    }
  }
}

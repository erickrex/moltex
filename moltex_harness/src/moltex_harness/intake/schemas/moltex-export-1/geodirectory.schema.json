{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moltex.dev/schemas/moltex-export-1/geodirectory.schema.json",
  "title": "Moltex GeoDirectory evidence",
  "type": "object",
  "required": ["schema_version", "post_types", "privacy"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "post_types": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["detail_storage", "fields", "search_fields", "sort_fields", "tabs"],
        "properties": {
          "detail_storage": {"type": "string"},
          "fields": {"type": "array"},
          "search_fields": {"type": "array"},
          "sort_fields": {"type": "array"},
          "tabs": {"type": "array"}
        }
      }
    },
    "privacy": {
      "type": "object",
      "required": ["excluded_field_keys"],
      "properties": {
        "excluded_field_keys": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
